# Postgres
POSTGRES_USER=automatic_kyc
POSTGRES_PASSWORD=automatic_kyc_password
POSTGRES_DB=automatic_kyc_db
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_ERLANG_COOKIE=mysecretcookie
RABBITMQ_PORT=5671
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Worker
WORKER_TYPE=kyc_worker
PREFETCH=1

# API <-> RabbitMQ TLS/mTLS (Spring Boot)
RABBITMQ_SSL_ENABLED=true
RABBITMQ_SSL_VERIFY_HOSTNAME=true
RABBITMQ_TRUSTSTORE_PASSWORD=changeit
RABBITMQ_KEYSTORE_PASSWORD=changeit

# API
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ISSUER=automatic-kyc
APP_ENV=dev
APP_ENCRYPTION_MASTER_KEY=change-me-to-32-bytes-base64-key=
KYC_FLOW_BASE_URL=https://verify.kyc_thesis.francmatyas.com/v
CORS_ALLOWED_ORIGINS=https://admin.kyc_thesis.francmatyas.com,https://verify.kyc_thesis.francmatyas.com

# API bootstrap (optional)
APP_BOOTSTRAP_ENABLED=false
APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me

# S3 / MinIO
S3_BUCKET=automatic-kyc-localhost
S3_WORKER_PRESIGN_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/automatic-kyc-localhost

# Traefik / HTTPS
ACME_EMAIL=your@email.com
API_HOST=api.kyc_thesis.francmatyas.com
ADMIN_HOST=admin.kyc_thesis.francmatyas.com
VERIFY_HOST=verify.kyc_thesis.francmatyas.com

# Admin frontend build args
VITE_ADMIN_API_URL=https://api.kyc_thesis.francmatyas.com
VITE_ADMIN_WS_URL=wss://api.kyc_thesis.francmatyas.com

# Verify frontend build args
VITE_VERIFY_API_BASE_URL=https://api.kyc_thesis.francmatyas.com
