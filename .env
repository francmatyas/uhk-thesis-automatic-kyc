# Postgres
POSTGRES_USER=automatic_kyc
POSTGRES_PASSWORD=automatic_kyc_password
POSTGRES_DB=automatic_kyc_db
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_ERLANG_COOKIE=mysecretcookie
RABBITMQ_PORT=5671
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Worker
WORKER_TYPE=kyc_worker
PREFETCH=1

# API <-> RabbitMQ TLS/mTLS (Spring Boot)
RABBITMQ_SSL_ENABLED=true
RABBITMQ_SSL_VERIFY_HOSTNAME=true
RABBITMQ_TRUSTSTORE_PATH=ops/api/certs/api-truststore.p12
RABBITMQ_TRUSTSTORE_PASSWORD=changeit
RABBITMQ_TRUSTSTORE_TYPE=PKCS12
RABBITMQ_KEYSTORE_PATH=ops/api/certs/api-keystore.p12
RABBITMQ_KEYSTORE_PASSWORD=changeit
RABBITMQ_KEYSTORE_TYPE=PKCS12
