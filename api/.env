S3_BUCKET=automatic-kyc-localhost
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_WORKER_PRESIGN_ENDPOINT=http://host.docker.internal:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/automatic-kyc-localhost

