# RabbitMQ configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5671
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_SSL_ENABLED=true
RABBITMQ_SSL_VERIFY_HOSTNAME=true
RABBITMQ_TRUSTSTORE_PATH=file:../ops/api/certs/api-truststore.p12
RABBITMQ_TRUSTSTORE_PASSWORD=changeit
RABBITMQ_TRUSTSTORE_TYPE=PKCS12
RABBITMQ_KEYSTORE_PATH=file:../ops/api/certs/api-keystore.p12
RABBITMQ_KEYSTORE_PASSWORD=changeit
RABBITMQ_KEYSTORE_TYPE=PKCS12

# S3-compatible object storage configuration
